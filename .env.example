# Ejemplo de variables de entorno (no commitees tu .env real)
# API base
VITE_API_BASE_URL=http://localhost:3000

# Observabilidad
VITE_SENTRY_DSN=

# Feature flags
VITE_FEATURE_AGENTS_PORTAL=1

# Entorno local multi-instance
# VITE_AGENT_NAME y PORT pueden usarse para levantar múltiples instancias locales
VITE_AGENT_NAME=agent0
PORT=8080
